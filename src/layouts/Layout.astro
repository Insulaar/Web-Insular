---
import { ViewTransitions } from 'astro:transitions';
interface Props { title?: string; }
const { title = "INSULAR ESTUDIO DE DISEÑO" } = Astro.props;
---
<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <link href="https://api.fontshare.com/v2/css?f[]=satoshi@300,301,400,401,500,501,700,701,900,901&display=swap" rel="stylesheet">
        
        <ViewTransitions />

        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
        <script is:inline src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
    </head>
    <body>
        <header class="header">
            <div class="header-item-reveal">
                <a href="/" class="logo-link">
                    <svg width="60" height="60" viewBox="0 0 98 98" fill="none">
                        <path d="M0 97.0627L68.9353 97.0627L68.9353 28.6618L0 28.6618L0 97.0627Z" fill="#1E1E1E"/>
                        <path d="M97.609 0H68.9762V28.6328H97.609V0Z" fill="#1E1E1E"/>
                    </svg>
                </a>
                <div class="item-overlay"></div>
            </div>
            
            <button class="menu-toggle" id="menu-btn" aria-label="Menu">
                <span></span>
                <span></span>
            </button>

            <nav class="nav-container" id="nav-menu">
                <div class="nav-links">
                    <div class="header-item-reveal">
                        <a href="/insular">INSULAR</a>
                        <div class="item-overlay"></div>
                    </div>

                    <div class="header-item-reveal">
                        <a href="/" class="tipito-link">
                            <img src="/img/tipito.png" alt="Work" width="64" height="64" />
                        </a>
                        <div class="item-overlay"></div>
                    </div>

                    <div class="header-item-reveal">
                        <a href="/contacto">CONTACTO</a>
                        <div class="item-overlay"></div>
                    </div>
                </div>
            </nav>
        </header>

        <main class="content-fade">
            <slot />
        </main>

        <footer class="site-footer">
            <div class="footer-grid">
                <div class="footer-item">
                    <h3>Insular</h3>
                    <p>2026 by Lue</p>
                </div>
                
                <div class="footer-item">
                    <h3>Ubicación</h3>
                    <p>LA PLATA, ARGENTINA</p>
                </div>

                <div class="footer-item">
                    <h3>Instagram</h3>
                    <a href="https://instagram.com/insulaar" target="_blank">@INSULAAR</a>
                </div>

                <div class="footer-item">
                    <h3>Contacto</h3>
                    <a href="mailto:INSULAAR.ESTUDIO@GMAIL.COM">INSULAAR.ESTUDIO@GMAIL.COM</a>
                </div>
            </div>
        </footer>

     <button onclick="window.scrollTo({top: 0, behavior: 'smooth'})" class="back-to-top" aria-label="Back to top">
  <img src="/backtotop.svg" alt="Back to top" class="back-icon" />
</button>

        <script>
            const setupLayout = () => {
                const btn = document.getElementById('menu-btn');
                const menu = document.getElementById('nav-menu');

                if (btn && menu) {
                    btn.onclick = () => {
                        btn.classList.toggle('open');
                        menu.classList.toggle('active');
                        document.body.classList.toggle('no-scroll');
                    };
                }
            };

            setupLayout();
            document.addEventListener('astro:after-swap', setupLayout);
        </script>

        <style is:global>
            :root {
                --margin: 50px; 
                --bg: #F7F7F7; 
                --black: #1E1E1E;
                --nav-size: 22px;
            }

            * { box-sizing: border-box; margin: 0; padding: 0; }
            html { scroll-behavior: smooth; }

            body { 
                font-family: 'Satoshi', sans-serif; 
                background: var(--bg); 
                color: var(--black); 
                display: flex;
                flex-direction: column;
                min-height: 100vh;
                overflow-x: hidden;
            }

/* Cuando WORK (dentro del main) tiene hover, el header se desvanece */
body:has(.work-trigger:hover) header {
    opacity: 0.3;
    transition: opacity 0.6s ease;
}

/* Pero el header recupera fuerza si pasamos el mouse directamente sobre él */
body:has(.work-trigger:hover) header:hover {
    opacity: 1;
}

            .content-fade {
                flex: 1;
                animation: fadeInUp 0.8s ease-out forwards;
            }

            @keyframes fadeInUp {
                from { opacity: 0; transform: translateY(15px); }
                to { opacity: 1; transform: translateY(0); }
            }

            /* --- HEADER --- */
            .header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 5px var(--margin);
                position: sticky;
                top: 0;
                z-index: 1000;
                background: rgba(247, 247, 247); 
                backdrop-filter: blur(2px);
                -webkit-backdrop-filter: blur(10px);
            }

            .header-item-reveal {
                position: relative;
                display: flex;
                align-items: center;
                cursor: crosshair;
            }

            .item-overlay {
                position: absolute;
                top: -5px;
                left: -10px;
                right: -10px;
                bottom: -5px;
                background-color: var(--bg);
                opacity: 0;
                visibility: hidden;
                backdrop-filter: blur(10px);
                -webkit-backdrop-filter: blur(10px);
                transition: opacity 0.4s ease, visibility 0.4s ease;
                z-index: 2;
                pointer-events: none;
                border-radius: 4px;
            }

            .header-item-reveal:hover .item-overlay {
                opacity: 0.7;
                visibility: visible;
            }

            .header-item-reveal a, 
            .header-item-reveal svg, 
            .header-item-reveal img {
                position: relative;
                z-index: 1;
            }

            .nav-links { display: flex; align-items: center; gap: 50px; }
            .nav-links a { 
                text-decoration: none; 
                color: var(--black); 
                font-weight: 500; 
                text-transform: uppercase; 
                font-size: var(--nav-size); 
            }

            .tipito-link img { height: 70px; width: auto; display: block; }
            .menu-toggle { display: none; }

            /* --- NUEVO FOOTER --- */
            .site-footer {
                background-color: #000;
                color: #fff;
                padding: 60px var(--margin);
                margin-top: 100px;
                font-family: 'Satoshi', sans-serif;
                position: relative;
                z-index: 10;
            }

            .footer-grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 40px;
                align-items: start;
                max-width: 1400px;
            }

            .footer-item h3 {
                font-size: 10px;
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                margin-bottom: 15px;
                opacity: 0.5;
            }

            .footer-item p, 
            .footer-item a {
                font-size: 13px;
                font-weight: 500;
                text-transform: uppercase;
                text-decoration: none;
                color: #fff;
                margin: 0;
                display: block;
            }

            /* BOTÓN BACK TO TOP */
            .back-to-top {
                position: fixed;
                bottom: 40px;
                right: var(--margin);
                background: none;
                border: none;
                color: #1E1E1E;
                cursor: pointer;
                z-index: 99999 !important; /* Aumentamos el valor para que pase por encima de todo */
                padding: 0px;
                mix-blend-mode: difference;
                pointer-events: all; /* Asegura que sea clickeable aunque algo flote cerca */
            }

            .back-icon {
  width: 60px; /* Ajustalo a tu gusto */
  height: auto;
  filter: invert(1); /* Fundamental para que el mix-blend-mode: difference funcione si el SVG es negro */
}

body.no-scroll .back-to-top {
    display: none !important;
}

.footer-item a {
    color: #fff !important;
    text-decoration: none;
}

.footer-item a:hover {
    opacity: 0.7; /* Un pequeño feedback al pasar el mouse */
}


.menu-toggle { 
    display: none; /* Asegura que NO aparezca en desktop */
}

  /* --- RESPONSIVE --- */
@media (max-width: 1000px) {
    :root { --margin: 20px; }

    body { 
        padding-top: 80px !important; /* Crea el espacio para el header fixed */
    }

    .header {
        position: fixed !important;
        top: 0;
        left: 0;
        width: 100%;
        height: 70px;
        padding: 0 var(--margin);
        background: var(--bg) !important;
        z-index: 2100;
        /* Mantenemos tu estética de desenfoque */
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }

    .logo-link svg {
        width: 48px;
        height: 48px;
    }

    .menu-toggle {
        display: flex !important;
        flex-direction: column;
        justify-content: center;
        align-items: flex-end;
        gap: 6px;
        background: none;
        border: none;
        width: 40px;
        height: 40px;
        z-index: 1100;
        cursor: pointer;
    }

    .menu-toggle span {
        display: block;
        width: 25px;
        height: 2px;
        background-color: var(--black);
        transition: all 0.3s ease;
    }

    .menu-toggle.open span:nth-child(1) { transform: translateY(4px) rotate(45deg); }
    .menu-toggle.open span:nth-child(2) { transform: translateY(-4px) rotate(-45deg); }

/* Ocultamos los links que NO están dentro del contenedor móvil */
    .header .nav-links {
        display: none !important;
    }

    /* Pero nos aseguramos de que los que están DENTRO del menú móvil SÍ se vean */
    .nav-container .nav-links {
        display: flex !important;
    }


    /* EL MENÚ OCULTO */
    .nav-container {
        position: fixed;
        top: 0;
        right: -100vw;
        width: 100vw;
        height: 100vh;
        background: var(--bg);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        z-index: 1050;
        visibility: hidden;
    }

    .nav-container.active {
        transform: translateX(-100vw);
        visibility: visible;
    }

    .nav-links { 
        display: flex !important;
        flex-direction: column; 
        gap: 40px; 
        text-align: center; 
    }
    
    .nav-links a { font-size: 32px; }
    .tipito-link img { height: 80px; }

    .footer-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 30px;
    }
}
     
.no-scroll {
    overflow: hidden !important;
    height: 100vh;
}

/* 1. Reset para que los nombres no se pongan azules ni se subrayen */
a {
  text-decoration: none; /* Quita el subrayado */
  color: inherit;       /* Hereda el color del padre (negro o blanco) */
  outline: none;        /* Quita el borde azul al hacer clic */
}

/* 2. Evitar el resaltado azul al tocar en móviles */
a, button {
  -webkit-tap-highlight-color: transparent;
}

/* 3. Específicamente para tus títulos en el home */
.project-card, .project-title {
  color: var(--black, #000); /* Asegura que siempre sea el color de tu marca */
  user-select: none;         /* Evita que el texto se "pinte" de azul al arrastrar el mouse */
}


        </style>
    </body>
</html>