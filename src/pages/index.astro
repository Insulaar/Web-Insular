---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

<Layout title="INSULAR ESTUDIO DE DISEÑO">
  <main class="home-wrapper">
    <header class="section-header">
      <div class="reveal-trigger work-trigger">
        <h1>WORK</h1>
        
        <div class="global-overlay"></div>

        <div class="work-video-container">
          <video autoplay loop muted playsinline>
            <source src="/img/video-work.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
    </header>
<section class="modular-grid">
      {sortedProjects.map((project) => {
        
        // --- ESTA ES LA LÓGICA DE REDIRECCIÓN ---
        // Si el proyecto tiene 'redirect' en el MD, usa eso. 
        // Si no, usa el link normal (limpiando el /index si existe).
        const targetLink = project.data.redirect 
          ? project.data.redirect 
          : `/projects/${project.id.replace(/\/index$/, '')}`;

        return (
          <a 
            href={targetLink} 
            class={`project-card ${project.data.visual}`}
            style={`
              grid-column-start: ${project.data.column || 'auto'};
              grid-column-end: ${project.data.visual === 'horizontal' ? 'span 2' : 'auto'};
              grid-row-start: ${project.data.row || 'auto'};
            `}
          >
            <div class="image-container">
              <Image 
                src={project.data.image} 
                alt={project.data.title} 
                width={1600} 
              />
              <div class="project-overlay">
                <span class="project-title">{project.data.title}</span>
              </div>
            </div>
          </a>
        );
      })}
    </section>
  </main>
</Layout>

<style>
/* 1. RESET Y GENERALES */
.project-card {
  text-decoration: none;
  display: block;
  color: inherit;
  -webkit-tap-highlight-color: transparent;
}

.home-wrapper {
  width: 100%;
  padding: 40px var(--margin) 120px var(--margin); 
  box-sizing: border-box;
  overflow-x: hidden; /* Evita cualquier carril blanco accidental */
}

.section-header {
  margin-bottom: 40px; 
}

.reveal-trigger {
  position: relative;
  display: inline-block;
  cursor: crosshair;
}

.section-header h1 {
  font-family: 'Satoshi', sans-serif;
  font-weight: 500;
  font-size: clamp(32px, 15vw, 197px);
  text-transform: uppercase;
  margin: 0;
  letter-spacing: -0.02em;
  line-height: 1;
  position: relative;
  z-index: 10002;
  transition: opacity 0.6s ease;
}

.work-trigger:hover h1 {
  opacity: 0.3;
}

/* 2. CAPA DE DESENFOQUE (Mantenemos tu interacción) */
.global-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: var(--bg);
  opacity: 0;
  visibility: hidden;
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  transition: opacity 0.6s ease, visibility 0.6s ease;
  z-index: 9999; 
  pointer-events: none;
}

.work-trigger:hover .global-overlay {
  opacity: 0.8;
  visibility: visible;
}

/* 3. VIDEO: Desktop */
.work-video-container {
  position: absolute; 
  top: 50%;
  left: 50%;
  transform: translate(78.8%, -5%); 
  width: 400px; 
  height: auto;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.6s ease, transform 0.7s ease; 
  z-index: 10001;
  pointer-events: none;
}

.work-trigger:hover .work-video-container {
  opacity: 1;
  visibility: visible;
  transform: translate(78.8%, -9.5%); 
}

.work-video-container video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* 4. GRILLA MODULAR */
.modular-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px; 
  align-items: start;
}

.image-container {
  position: relative;
  background: #f4f4f4;
  overflow: hidden;
  width: 100%;
}

.project-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(247, 247, 247, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.project-title {
  font-size: 13px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}

.project-card:hover .project-overlay { opacity: 1; }
.project-card:hover img { transform: scale(1.02); opacity: 0.8; }

.project-card.cuadrado .image-container { aspect-ratio: 1 / 1; }
.project-card.horizontal .image-container { aspect-ratio: 2.03 / 1; }

/* REGLA CRÍTICA DE IMAGEN (Sin !important dañinos) */
img {
  max-width: 100%;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
}

/* 5. MOBILE RESPONSIVE (Limpieza total) */
@media (max-width: 768px) {
  .home-wrapper {
    padding: 5px var(--margin) 80px var(--margin); 
  }

 .section-header {
  padding: 0; /* WORK se alineará con el borde del home-wrapper */
  margin-bottom: 29px; 
}

  .reveal-trigger.work-trigger {
    display: block;
    width: 100%;
  }

  .section-header h1 {
    font-size: clamp(60px, 18vw, 95px);
    line-height: 0.9;
  }

  .modular-grid { 
    display: flex;
    flex-direction: column;
    gap: 20px; /* <--- Cambiá este valor (antes estaba en 48px) */
  }

  .project-overlay { 
    position: relative; 
    display: flex; 
    opacity: 1; 
    background: transparent;
    padding: 15px var(--margin) 5px var(--margin);
  }

  /* VIDEO EN MOBILE: Centrado con márgenes reales */
  .work-video-container {
    left: 50%;
    right: auto;
    top: 110%;
    width: calc(100% - (var(--margin) * 2));
    max-width: 450px;
    transform: translate(-50%, 10px) scale(0.98);
  }

  .work-trigger:hover .work-video-container {
    transform: translate(-50%, 0) scale(1);
  }
}
</style>