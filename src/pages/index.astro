---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

<Layout title="INSULAR STUDIO">
  <main class="home-wrapper">
    <header class="section-header">
      <div class="reveal-trigger work-trigger">
        <h1>WORK</h1>
        
        <div class="global-overlay"></div>

        <div class="work-video-container">
          <video autoplay loop muted playsinline>
            <source src="/img/video-work.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
    </header>
<section class="modular-grid">
      {sortedProjects.map((project) => {
        
        // --- ESTA ES LA LÓGICA DE REDIRECCIÓN ---
        // Si el proyecto tiene 'redirect' en el MD, usa eso. 
        // Si no, usa el link normal (limpiando el /index si existe).
        const targetLink = project.data.redirect 
          ? project.data.redirect 
          : `/projects/${project.id.replace(/\/index$/, '')}`;

        return (
          <a 
            href={targetLink} 
            class={`project-card ${project.data.visual}`}
            style={`
              grid-column-start: ${project.data.column || 'auto'};
              grid-column-end: ${project.data.visual === 'horizontal' ? 'span 2' : 'auto'};
              grid-row-start: ${project.data.row || 'auto'};
            `}
          >
            <div class="image-container">
              <Image 
                src={project.data.image} 
                alt={project.data.title} 
                width={1600} 
              />
              <div class="project-overlay">
                <span class="project-title">{project.data.title}</span>
              </div>
            </div>
          </a>
        );
      })}
    </section>
  </main>
</Layout>

<style>
  .home-wrapper {
    width: 100%;
    padding: 40px var(--margin) 120px var(--margin); 
    box-sizing: border-box;
  }

  .section-header {
    margin-bottom: 40px; 
  }

  .reveal-trigger {
    position: relative;
    display: inline-block;
    cursor: crosshair;
  }

  .section-header h1 {
    font-family: 'Satoshi', sans-serif;
    font-weight: 500;
    font-size: clamp(32px, 15vw, 197px);
    text-transform: uppercase;
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1;
    position: relative;
    z-index: 10002; /* Por encima de todo */
    transition: opacity 0.6s ease;
  }

  .work-trigger:hover h1 {
    opacity: 0.3;
  }

  /* CAPA DE DESENFOQUE */
  .global-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: var(--bg);
    opacity: 0;
    visibility: hidden;
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    transition: opacity 0.6s ease, visibility 0.6s ease;
    z-index: 9999; 
    pointer-events: none;
  }

  .work-trigger:hover .global-overlay {
    opacity: 0.8;
    visibility: visible;
  }

  /* CONTENEDOR DE VIDEO: Posición Fija y Tamaño Controlado */
/* 1. ESTADO INICIAL (OCULTO) */
  .work-video-container {
    position: absolute; 
    top: 50%;
    left: 50%;
    
    /* X se queda igual al hover para que no venga del costado */
    /* Y está en -5% (apenas más abajo que el final) */
    transform: translate(78.8%, -5%); 
    
    width: 400px; 
    height: auto;
    visibility: hidden;
    opacity: 0;
    
    /* Bajamos el tiempo a 0.4s para que sea más reactivo y elegante */
    transition: opacity 0.6s ease, transform 0.7s ease; 
    z-index: 10001;
    pointer-events: none;
  }

  /* 2. ESTADO AL HACER HOVER (SUBE A SU LUGAR) */
  .work-trigger:hover .work-video-container {
    opacity: 1;
    visibility: visible;
    
    /* X se mantiene en 78.8% para que no haya movimiento horizontal */
    /* Y sube a -9.5% (el lugar que ya encontraste) */
    transform: translate(78.8%, -9.5%); 
  }
  .work-video-container video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* GRILLA MODULAR */
  .modular-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px; 
    align-items: start;
  }

  .project-card {
    text-decoration: none;
    display: block;
  }

  .image-container {
    position: relative;
    background: #f4f4f4;
    overflow: hidden;
    width: 100%;
  }

  .project-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(247, 247, 247, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .project-title {
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .project-card:hover .project-overlay { opacity: 1; }
  .project-card:hover img { transform: scale(1.02); opacity: 0.8; }

  .project-card.cuadrado .image-container { aspect-ratio: 1 / 1; }
  .project-card.horizontal .image-container { aspect-ratio: 2.03 / 1; }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
  }

/* MOBILE RESPONSIVE - GRILLA Y VIDEO CORREGIDO */
@media (max-width: 768px) {
  .home-wrapper {
    /* 1. Espacio arriba de WORK (Ajusta este número a tu gusto) */
    padding: 5px 0 80px 0 !important; 
    width: 100%;
  }

 .section-header {
    padding: 0 var(--margin);
    /* 2. Espacio abajo de WORK (Mismo valor que el padding-top del wrapper) */
    margin-bottom: 20px !important; 
    display: block; 
    text-align: left;
  }

  /* IMPORTANTE: Forzamos que el trigger ocupe el ancho para poder centrar el video */
  .reveal-trigger.work-trigger {
    display: block !important;
    width: 100%;
    position: relative;
  }

  .section-header h1 {
    font-size: clamp(60px, 18vw, 95px) !important;
    text-align: left;
    line-height: 0.9;
    display: inline-block;
  }

  .modular-grid { 
    display: flex;
    flex-direction: column;
    gap: 48px; 
    width: 100%;
  }

  .project-card {
    width: 100%;
    position: relative;
  }

  .project-overlay { 
    position: relative; 
    display: flex; 
    opacity: 1; 
    background: transparent;
    justify-content: flex-start;
    padding: 15px var(--margin) 5px var(--margin);
    height: auto;
  }

  .project-title {
    font-size: 12px;
    color: var(--black);
    opacity: 0.7;
  }

  /* VIDEO EN MOBILE: Centrado y dentro de márgenes */
  .work-video-container {
    position: absolute;
    top: 110% !important; 
    
    /* Centrado real */
    left: 0 !important;
    right: 0 !important;
    margin: 0 auto !important; 
    
    /* Ancho exacto igual al margen del logo y los textos */
    width: calc(100% - (var(--margin) * 0)) !important; 
    /* Si quieres que tenga un airecito a los lados, usa: calc(100% - 40px) */
    
    max-width: 450px;
    height: auto;
    
    /* Efecto de entrada suave */
    transform: translateY(10px) scale(0.98) !important;
    
    z-index: 10001;
    transition: opacity 0.4s ease, transform 0.5s ease;
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
  }

  .work-trigger:hover .work-video-container {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1) !important;
  }

  .work-video-container video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
}