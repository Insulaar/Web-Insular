---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets'; // 1. Agregá esta importación arriba

// Aquí le decimos a Astro: "Traeme todos los proyectos que encuentres"
const projects = await getCollection('projects');
---
<Layout title="WORK - INSULAR STUDIO">
	<main class="home-container">
		<h1 class="main-title">WORK</h1>
		
	<div class="masonry-grid">
	{
		projects.map((project) => (
			<a href={`/projects/${project.slug}`} class="project-card">
				<Image 
					src={project.data.cover} 
					alt={project.data.title} 
					width={800} 
					format="webp"
				/>
				<div class="project-info">
					<p>{project.data.title}</p>
				</div>
			</a>
		))
	}
</div>
	</main>
</Layout>

<style>
	/* Contenedor Principal */
	.home-container {
  padding: 0 var(--margin); /* Esto alinea el contenido con el logo y el footer */
  margin-top: 100px;
  margin-bottom: 150px; /* Le da aire al footer para que no se pegue */
}

	/* Título Principal con aire editorial */
	.main-title { 
		font-size: 48px; 
		font-weight: 500;
		text-transform: uppercase;
		margin-top: 20px; 
		margin-bottom: 20px; 
		letter-spacing: -0.02em;
	}

	/* Grilla Masonry */
	.masonry-grid {
  display: grid;
  grid-template-columns: repeat(9, 1fr); /* Volvemos a la grilla de 9 para ser consistentes */
  gap: var(--gap);
}

	/* Tarjeta de Proyecto */
	.project-card {
		position: relative;
		display: block;
		margin-bottom: var(--gap);
		overflow: hidden;
		background: var(--gray-light);
		cursor: pointer;
	}

	/* Imagen con efecto Zoom */
	.project-card {
  grid-column: span 4; /* Las tarjetas ocupan casi la mitad, dejando aire */
  text-decoration: none;
  color: inherit;
}
	.project-card:hover img {
		transform: scale(1.05);
	}

	/* Info que aparece al hacer Hover */
	.project-info {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: rgba(0, 0, 0, 0.3); /* Oscurece la foto para leer el texto */
		opacity: 0;
		transition: opacity 0.4s ease;
		pointer-events: none;
	}

	.project-card:hover .project-info {
		opacity: 1;
	}

	.project-info p {
		color: white;
		text-transform: uppercase;
		font-size: 1.1rem;
		letter-spacing: 2px;
		font-weight: 500;
	}

	/* Responsivo */
	@media (max-width: 900px) { 
		.masonry-grid { column-count: 2; } 
	}

	@media (max-width: 600px) { 
		.masonry-grid { column-count: 1; } 
		.main-title { font-size: 32px; margin-bottom: 60px; }
	}
</style>