---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects
    .filter(entry => !entry.data.redirect) 
    .map(entry => ({
      params: { slug: entry.id.replace(/\/index$/, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
  <article class="project-page">
    <header class="section-header">
      <h1 class="f-bold title-main">{entry.data.title}</h1>
    </header>

    <div class="markdown-render">
      <Content />
    </div>
  </article>
</Layout>

<style is:global>
  /* 1. VARIABLES Y RESET DE MÁRGENES */
  :root { 
    --margin: 50px !important; 
  }

  @media (max-width: 768px) { 
    :root { --margin: 20px !important; } 
  }

  .project-page { 
    width: 100%; 
    overflow-x: hidden; 
    display: block;
  }

  /* 2. HEADER: IGUAL AL HOME (WORK) */
  .section-header {
    padding: 40px var(--margin) 40px var(--margin) !important;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .title-main {
    font-family: 'Satoshi', sans-serif !important;
    font-weight: 500 !important;
    font-size: clamp(32px, 15vw, 197px) !important;
    line-height: 1 !important;
    text-transform: uppercase;
    margin: 0 !important;
    letter-spacing: -0.02em !important; /* Igual al index */
    transition: opacity 0.6s ease;
    cursor: crosshair;
  }

  .title-main:hover { 
    opacity: 0.3; 
  }

  /* 3. ESTRUCTURA DE CONTENIDO (BLOQUEO DE PARPADEO) */
  .markdown-render {
    display: flex;
    flex-direction: column;
   gap: 45px !important; /* <--- ESTE es el que separa video de texto en mobile */
    padding: 0 var(--margin) 150px var(--margin) !important;
    min-height: 100vh; /* Evita saltos visuales al cargar */
  }

  /* Solución al problema de las imágenes en párrafos */
  .markdown-render > p { 
    display: contents !important; 
  }

  /* 4. REGLAS PARA TEXT-BOX (PROTECCIÓN DE TIPOGRAFÍA) */
  /* Forzamos que el contenido de text-box siempre sea visible y con formato */
  .text-box {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .text-box p, 
  .text-box span {
    display: block !important;
    font-family: 'Satoshi', sans-serif !important;
    line-height: 1.2 !important;
    margin: 0 !important;
    /* Esto asegura que hereden las clases f-bold, t-large, etc. */
    font-size: inherit;
    font-weight: inherit;
    text-transform: inherit;
  }

  /* 5. DISEÑO DESKTOP (GRILLA) */
  @media (min-width: 769px) {
    .markdown-render {
      display: grid !important;
      grid-template-columns: 1.2fr 0.8fr !important; 
      column-gap: 80px;
      row-gap: 120px;
      align-items: start;
    }

    /* Elementos por defecto a la izquierda */
    .markdown-render > * { 
      grid-column: 1 / 2 !important; 
    }

    /* Caja de texto a la derecha */
    .markdown-render .text-box { 
      grid-column: 2 / 3 !important;
    }
  }

/* 6. MULTIMEDIA & GRID CONTROL */
  
  /* Forzamos que el enlace que envuelve la imagen respete la columna izquierda */
  .markdown-render a.glightbox {
    grid-column: 1 / 2 !important;
    display: block;
    width: 100% !important;
  }

  /* La imagen dentro del enlace debe ocupar todo el ancho disponible */
  .markdown-render a.glightbox img {
    width: 100% !important;
    height: auto !important;
    display: block;
    object-fit: cover;
  }

  /* Los videos (que no tienen <a>) también a la izquierda */
  .markdown-render video {
    grid-column: 1 / 2 !important;
    width: 100% !important;
    height: auto !important;
    display: block;
    object-fit: cover;
  }

  /* 7. CLASES DE UTILIDAD (Refuerzo por si fallan al recargar) */
  .f-bold { font-weight: 500 !important; }
  .f-light { font-weight: 300 !important; }

 /* VARIANTES DE PESO (Aptas para Satoshi) */
  .f-regular { font-weight: 400 !important; }
  .f-medium  { font-weight: 500 !important; }
  .f-black   { font-weight: 900 !important; }

  /* VARIANTES DE TAMAÑO */
  .t-xl      { font-size: 60px !important; }
  .t-large   { font-size: 65px !important; }
  .t-medium  { font-size: 40px !important; }
  .t-small   { font-size: 20px !important; }

  /* VARIANTES DE ESPACIADO (Variable extra para diseño) */
  .ls-tight  { letter-spacing: -0.04em !important; }
  .ls-normal { letter-spacing: 0em !important; }


  .upper { text-transform: uppercase !important; }

@media (max-width: 768px) {
  .t-large {
    /* Ajustamos el tamaño para que no desborde en mobile */
    font-size: 28px !important; 
    line-height: 1.1 !important;
  }

  .t-medium {
    font-size: 18px !important;
  }

  .text-box {
    /* Reducimos el espacio entre el título y el subtítulo */
    gap: 10px !important;
  }
}


/* 9. ESTÉTICA EDITORIAL PARA LIGHTBOX (IMÁGENES Y VIDEOS) */

/* Fondo del overlay: usamos el gris claro de tu estudio con un desenfoque sutil */
.goverlay {
  background: rgba(245, 245, 245, 0.98) !important; 
  backdrop-filter: blur(6px); /* Efecto de vidrio esmerilado */
}

/* LIMPIEZA TOTAL: Eliminamos bordes, sombras y fondos internos */
.gslide-image img, 
.gslide-video,
.gvideo-container,
.gslide-inline,
.gslide-media {
  box-shadow: none !important;
  border-radius: 0 !important;
  background: transparent !important;
}

/* ELIMINACIÓN DE BORDES NEGROS: Forzamos que el contenedor de video sea transparente */
.gvideo-container {
  background: transparent !important;
}

/* Transición FADE: Reemplazamos el salto de zoom por un desvanecimiento suave */
.gfadeIn {
  animation: gfadeIn 0.4s ease-in-out !important;
}

.gfadeOut {
  animation: gfadeOut 0.4s ease-in-out !important;
}

/* BOTÓN CERRAR: Minimalista y sin círculo de fondo */
.gclose {
  background: transparent !important;
  opacity: 0.8;
  transition: opacity 0.3s ease;
}

.gclose:hover {
  opacity: 1;
}

.gclose path {
  fill: #1E1E1E !important; /* El color de tu marca */
}

/* Cursor de zoom para las miniaturas en la página */
.markdown-render img, 
.markdown-render video {
  cursor: zoom-in !important;
  transition: filter 0.3s ease !important;
}

.markdown-render img:hover, 
.markdown-render video:hover {
  filter: brightness(0.9); /* Un feedback visual muy sutil */
}
/* Aseguramos que el botón de cerrar sea clickeable y visible */
  .gclose {
    position: fixed !important;
    top: 20px !important;
    right: 20px !important;
    z-index: 999999 !important;
    cursor: pointer !important;
    width: 45px !important;
    height: 45px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  /* Permitir salir haciendo clic en el fondo gris */
  .gslide {
    cursor: pointer; /* Indica que se puede hacer clic para salir */
  }

  .gslide-content {
    cursor: default; /* Evita que la imagen misma parezca que cierra al clic si no querés */
  }

/* ELIMINACIÓN DEFINITIVA DE BORDES NEGROS EN VIDEOS */
  
  /* Forzamos transparencia en todos los niveles del reproductor */
  .plyr, 
  .plyr__video-wrapper, 
  .plyr__poster,
  .plyr--video {
    background: transparent !important;
    background-color: transparent !important;
  }

  /* Ajuste de escala para que no se generen huecos */
  .gvideo-container video {
    background: transparent !important;
    height: 90vh !important;
    width: auto !important;
    max-width: 100% !important;
    object-fit: contain; /* Mantiene la proporción sin estirar */
  }

  /* Quitamos cualquier sombra interna del slide de video */
  .gslide-video {
    box-shadow: none !important;
  }

/* Forzamos que el slide (contenedor principal) sea un flexbox centrado */
.gslide {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  width: 100vw !important; /* Viewport completo */
  height: 100vh !important;
  
}

/* El contenido multimedia dentro debe ignorar márgenes externos */
.gslide-content {
  margin: 0 !important;
  padding: 0 !important;
  max-width: 90vw !important; /* Limitamos ancho máximo por aire */
  max-height: 90vh !important; /* Limitamos altura máxima */
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* Aseguramos que las imágenes y videos no se estiren, sino que floten centrados */
.gslide-image,
.gvideo-container {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  max-width: 100% !important;
  max-height: 100% !important;
}

/* Pequeño ajuste responsive: si en mobile se veía bien, */
/* nos aseguramos de no romperlo con el flex global. */
@media (max-width: 768px) {
  .gslide-content {
    max-width: 100vw !important;
    padding: var(--margin) !important;
  }
}

</style>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    // 1. LÓGICA PARA IMÁGENES: Envolver cada img en un <a>
    const images = document.querySelectorAll('.markdown-render img');
    images.forEach(img => {
      const wrapper = document.createElement('a');
      wrapper.href = img.src;
      wrapper.classList.add('glightbox'); 
      
      img.parentNode.insertBefore(wrapper, img);
      wrapper.appendChild(img);
    });

    // 2. LÓGICA PARA VIDEOS: Apertura tipo Loop sin controles (estética minimalista)
    const videos = document.querySelectorAll('.markdown-render video');
    videos.forEach(video => {
      video.addEventListener('click', (e) => {
        e.preventDefault();
        const myLightbox = GLightbox({
          elements: [{
            'href': video.querySelector('source')?.src || video.src,
            'type': 'video',
            'source': 'local',
            'width': 'auto', 
            'height': '90vh' 
          }],
          autoplayVideos: true,
          touchNavigation: true,
          zoomable: false,
          openEffect: 'fade',
          closeEffect: 'fade',
          // Configuración de Plyr optimizada para loops verticales
          plyr: {
            config: {
              controls: [], 
              muted: true,  
              hideControls: true,
              clickToPlay: false,
              loop: { active: true },
              ratio: null,     // Anula el forzado de 16:9 para eliminar bordes negros
              settings: []     // Elimina menús internos de configuración
            }
          }
        });
        myLightbox.open();
      });
    });

    // 3. INICIALIZACIÓN GLOBAL: Para las imágenes
    const lightbox = GLightbox({
      selector: '.glightbox',
      openEffect: 'fade', 
      closeEffect: 'fade',
      closeOnOutsideClick: true, 
      keyboardNavigation: true,   
      loop: true,
      descPosition: 'bottom',
    });
  });
</script>