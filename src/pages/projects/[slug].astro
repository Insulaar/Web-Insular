---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  
  // FILTRO: Solo generamos páginas para los que NO tienen redirect
  return projects
    .filter(entry => !entry.data.redirect) 
    .map(entry => ({
      params: { slug: entry.id.replace(/\/index$/, '') },
      props: { entry },
    }));
} // <--- Faltaba esta llave

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
  <article class="project-page">
    <header class="section-header">
      <div class="header-item-reveal work-trigger">
        <h1>{entry.data.title}</h1>
        <div class="item-overlay"></div>
      </div>
    </header>

    <div class="markdown-render">
      <Content />
    </div>
  </article>
</Layout>

<style is:global>
  /* --- ESTRUCTURA DE LA PÁGINA --- */
  .project-page {
    width: 100%;
    padding: 80px var(--margin) 120px var(--margin);
  }

  .section-header {
    margin-bottom: 80px; 
  }

  .section-header h1 {
    font-size: clamp(5rem, 15vw, 12rem);
    line-height: 0.8;
    letter-spacing: -0.04em;
    font-weight: 500;
    color: var(--text-color, #1a1a1a);
    text-transform: uppercase;
    margin: 0;
    padding-left: calc(var(--margin) * -0.05);
  }

  /* --- GRILLA FLEXIBLE --- */
  .markdown-render {
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  /* --- ESTILO DE LOS PÁRRAFOS (TEXTO + IMAGEN) --- */
  .markdown-render p {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    column-gap: 80px !important;
    align-items: start !important; 
    width: 100%;
    font-family: 'Satoshi', sans-serif; 
    font-weight: 300; 
    font-size: 2rem; 
    line-height: 1.2;
    text-transform: uppercase;
    padding-top: 5px; 
    color: var(--text-color, #1a1a1a);
  }

  .markdown-render p img, 
  .markdown-render p video {
    grid-column: 1 / 2 !important;
    width: 100% !important;
    height: auto !important;
    margin-top: 0px !important; 
  }

  /* --- CONTROL DE ANCHO COMPLETO --- */
  .markdown-render .full-v,
  .markdown-render > video,
  .markdown-render > img {
    display: block !important;
    width: 100% !important;
  }

  .markdown-render .full-v video {
    width: 100vw !important;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw !important;
    margin-right: -50vw !important;
    height: auto;
    max-height: 90vh;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .project-page {
      padding: 22px var(--margin) 80px var(--margin) !important;
    }

    .section-header {
      margin-bottom: 35px !important;
    }

    .section-header h1 {
      /* 1. Ajuste Dinámico: Usamos clamp para que el texto nunca sea más ancho que la pantalla */
      font-size: clamp(3rem, 16vw, 5.5rem) !important;
      line-height: 0.9;
      letter-spacing: -0.05em;
      margin: 0 !important;
      
      /* 2. Control de Desbordamiento: Forzamos el ajuste de palabras largas */
      overflow-wrap: break-word;
      word-wrap: break-word;
      word-break: break-word; /* Corta la palabra si es estrictamente necesario */
      hyphens: auto; /* Agrega guiones si el navegador lo soporta */
      
      width: 100%;
      display: block;
    }

    .markdown-render {
      gap: 50px !important;
    }

    .markdown-render p {
      grid-template-columns: 1fr !important;
      gap: 35px !important;
      padding-top: 0 !important;
      font-size: 1.1rem !important;
      line-height: 1.3;
    }

    .markdown-render p img, 
    .markdown-render p video {
      margin-top: 0 !important;
      width: 100% !important;
    }
  }
</style>