---
import Layout from '../layouts/Layout.astro';
---

<Layout title="INSULAR | INSULAR STUDIO">
  <main class="page-container">
    <section class="content-grid">
      <div class="title-col">
        <h1>INSULAR</h1>
      </div>
      <div class="text-col">
        <p class="placeholder-text">Próximamente: Manifiesto, equipo y visión de Insular Studio.</p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-container {
    padding: 150px var(--margin); /* Ajustado para que respire igual que los proyectos */
    min-height: 70vh;
  }
  
  .content-grid {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    gap: var(--gap);
  }
  
  .title-col { 
    grid-column: span 3; 
  }
  
  .text-col { 
    grid-column: 5 / span 5; 
  }
  
  h1 { 
    font-size: 48px; 
    font-weight: 500; 
    text-transform: uppercase; 
    line-height: 0.9;
  }
  
  .placeholder-text { 
    font-size: 36px; 
    line-height: 1.1; 
    font-weight: 400; 
    letter-spacing: -0.02em;
  }

  /* Responsivo: para que no se peguen las columnas en móvil */
  @media (max-width: 900px) {
    .page-container {
      padding: 100px var(--margin);
    }
    .content-grid {
      display: flex;
      flex-direction: column;
      gap: 30px;
    }
    h1 { font-size: 32px; }
    .placeholder-text { font-size: 24px; }
  }
</style>