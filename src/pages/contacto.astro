---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CONTACTO | INSULAR STUDIO">
  <main class="page-container">
    <section class="content-grid">
      <div class="title-col">
        <h1>CONTACTO</h1>
      </div>
      <div class="text-col">
        <p class="placeholder-text">¿Tenés un proyecto en mente?<br/>Escribinos a: <a href="mailto:insulaar.estudio@gmail.com">insulaar.estudio@gmail.com</a></p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-container {
    padding: 100px var(--margin);
    min-height: 60vh;
  }
  .content-grid {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    gap: var(--gap);
  }
  .title-col { grid-column: span 3; }
  .text-col { grid-column: 5 / span 5; }
  
  h1 { font-size: 48px; font-weight: 500; text-transform: uppercase; }
  .placeholder-text { font-size: 36px; line-height: 1.1; font-weight: 400; }
  a { color: inherit; text-decoration: underline; text-underline-offset: 4px; }
</style>