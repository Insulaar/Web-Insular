---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CONTACTO | INSULAR STUDIO">
  <main class="page-container">
    <section class="content-grid">
      <div class="title-col">
        <h1>CONTACTO</h1>
      </div>
      <div class="text-col">
        <p class="placeholder-text">
          ¿Tenés un proyecto en mente?<br/>
          Escribinos a: <br class="mobile-only"/>
          <a href="mailto:insulaar.estudio@gmail.com" class="email-link">insulaar.estudio@gmail.com</a>
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-container {
    /* Mismo respiro que la página Insular y proyectos */
    padding: 150px var(--margin); 
    min-height: 70vh;
    display: flex;
    flex-direction: column;
  }
  
  .content-grid {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    gap: var(--gap);
    width: 100%;
  }
  
  .title-col { 
    grid-column: span 3; 
  }
  
  .text-col { 
    grid-column: 5 / span 5; 
  }
  
  h1 { 
    font-size: 48px; 
    font-weight: 500; 
    text-transform: uppercase; 
    line-height: 0.9;
    margin: 0;
  }
  
  .placeholder-text { 
    font-size: 36px; 
    line-height: 1.1; 
    font-weight: 400; 
    letter-spacing: -0.02em;
    margin: 0;
  }

  .email-link { 
    color: inherit; 
    text-decoration: underline; 
    text-underline-offset: 4px;
    transition: opacity 0.3s ease;
  }

  .email-link:hover {
    opacity: 0.6;
  }

  .mobile-only {
    display: none;
  }

  /* Responsivo: Ajuste exacto a la estética de Insular Studio */
  @media (max-width: 900px) {
    .page-container {
      padding: 120px var(--margin) 80px var(--margin);
    }
    
    .content-grid {
      display: flex;
      flex-direction: column;
      gap: 40px; /* Un poco más de aire entre h1 y texto */
    }

    h1 { 
      font-size: 32px; 
    }

    .placeholder-text { 
      font-size: 24px; 
    }

    .mobile-only {
      display: block;
    }

    .email-link {
      /* Evita que el mail desborde y rompa el ancho de la página en celulares */
      word-break: break-all;
      display: inline-block;
      margin-top: 10px;
    }
  }
</style>